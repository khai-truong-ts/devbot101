SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
# Option A: API key (recommended for cloud)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Option B: OAuth credentials (run: base64 -i ~/.claude/.credentials.json)
CLAUDE_CREDENTIALS_B64=
ALLOWED_CHANNEL_IDS=C123ABC,C456DEF
ALLOWED_USER_IDS=
DATABASE_URL=postgresql://bot:bot@db:5432/botdb
AUDIT_LOG_ENABLED=false
DIRECT_REPLY_ENABLED=false
MAX_CONCURRENT_SESSIONS=10
CLAUDE_TIMEOUT_SECONDS=600
SLACK_MAX_CHARS=3800
SESSION_FILE_PATH=/workspace/sessions.json
